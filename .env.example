# 複製成 .env.local（本機）或填到 Vercel 的 Environment Variables（線上）

# ---- LINE Messaging API（在 LINE Developers Console 取得）----
LINE_CHANNEL_ACCESS_TOKEN=你的_channel_access_token
LINE_CHANNEL_SECRET=你的_channel_secret

# ---- Supabase（Project Settings → API）----
SUPABASE_URL=https://xxxx.supabase.co
# 注意：是 service_role 或 secret key（後端用），不是 anon/publishable。只放後端，別外洩。
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_或_secret_key

# ---- 排程保護（建議設一組隨機字串，pg_cron 那邊要帶同一組）----
CRON_SECRET=隨便一串夠長的隨機字

# ---- AI 助手（選用；兩家擇一即可，沒填則 AI 停用，其他指令照常）----
# 要用哪家：gemini 或 anthropic。留空則「哪個金鑰有填就用哪個」。
AI_PROVIDER=gemini

# 方案 A：Google Gemini（在 Google AI Studio 申請，免費層免綁卡）
GEMINI_API_KEY=你的_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# 方案 B：Anthropic Claude（在 console.anthropic.com 申請，需付款設定）
# ANTHROPIC_API_KEY=你的_anthropic_api_key
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- 紀念冊網頁網址（生命之書回顧/紀念冊連結要用）----
# 填你的 Vercel 網址，例如 https://gongyang-line-bot.vercel.app
# 不填的話，Vercel 上會自動用系統變數 VERCEL_PROJECT_PRODUCTION_URL
PUBLIC_BASE_URL=https://你的網址.vercel.app
