# 複製成 .env.local（本機）或填到 Vercel 的 Environment Variables（線上）

# ---- LINE Messaging API（在 LINE Developers Console 取得）----
LINE_CHANNEL_ACCESS_TOKEN=你的_channel_access_token
LINE_CHANNEL_SECRET=你的_channel_secret

# ---- Supabase（Project Settings → API）----
SUPABASE_URL=https://xxxx.supabase.co
# 注意：是 service_role key（後端用），不是 anon key。只放在後端環境變數，別外洩。
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_key

# ---- 排程保護（建議設一組隨機字串，pg_cron 那邊要帶同一組）----
CRON_SECRET=隨便一串夠長的隨機字

# ---- AI 助手（選用；沒填則 AI 功能停用，其他指令照常）----
AI_PROVIDER=gemini or anthropic
GEMINI_API_KEY=你的_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=你的_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001